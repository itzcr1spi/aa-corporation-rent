# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env` for local development. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database — matches docker-compose. `docker compose up -d db` then use this URL.
DATABASE_URL=postgres://aa:aa_dev_password@localhost:5432/aa_rental

# Storage: "local" (disk, dev only) or "s3" (added in the document-upload phase).
STORAGE_DRIVER=local
# S3-compatible object storage (MinIO in dev / Hetzner Object Storage in prod).
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_BUCKET=aa-rental
S3_ACCESS_KEY_ID=aa
S3_SECRET_ACCESS_KEY=aa_dev_password
S3_FORCE_PATH_STYLE=true

# Admin auth (Auth.js). REQUIRED for the admin panel — generate with:
#   openssl rand -base64 32
AUTH_SECRET=
# First admin is created via:  npm run admin:create -- <email> <password> "Name"

# Analytics / marketing — loaded only behind RODO/GDPR consent (Phase 14).
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Notifications (Phase 7) — email + SMS.
RESEND_API_KEY=
SMSAPI_TOKEN=
